<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- macOS hardened-runtime entitlement for microphone capture. Required
     alongside NSMicrophoneUsageDescription (Info.plist) once the app is signed
     with the hardened runtime (notarized / release builds); harmless for
     unsigned dev builds. Referenced from tauri.conf.json bundle.macOS.entitlements. -->
<plist version="1.0">
<dict>
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
