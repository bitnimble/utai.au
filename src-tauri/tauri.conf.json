{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "utai.au",
  "version": "0.1.0",
  "identifier": "au.utai.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build && bun run desktop:resources"
  },
  "app": {
    "windows": [
      {
        "title": "utai.au",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost ipc: http://ipc.localhost blob: data: https:; script-src 'self' 'wasm-unsafe-eval' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; object-src 'none'; base-uri 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/python/": "python/",
      "resources/bin/": "bin/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
