{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",

      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_evaluate",

      "mcp__plugin_linear_linear__*",

      "Bash(bun install)",
      "Bash(bun run build:*)",
      "Bash(bun typecheck:*)",
      "Bash(bun run typecheck:*)",
      "Bash(bun lint:design:*)",
      "Bash(bun run lint:design:*)",
      "Bash(bun format:*)",
      "Bash(bun run format:*)",
      "Bash(bun add:*)",
      "Bash(bun run test:*)",
      "Bash(bun run e2e:*)",
      "Bash(bun run e2e:run:*)",
      "Bash(bun run e2e:perf:*)",
      "Bash(bun run e2e:report:*)",
      "Bash(bun run build-storybook:*)",
      "Bash(bun run postinstall:*)",

      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git commit:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(git reset:*)",

      "Bash(git -C */.paseo/worktrees/* status:*)",
      "Bash(git -C */.paseo/worktrees/* add:*)",
      "Bash(git -C */.paseo/worktrees/* mv:*)",
      "Bash(git -C */.paseo/worktrees/* rm:*)",
      "Bash(git -C */.paseo/worktrees/* show:*)",
      "Bash(git -C */.paseo/worktrees/* diff:*)",
      "Bash(git -C */.paseo/worktrees/* log:*)",
      "Bash(git -C */.paseo/worktrees/* commit:*)",
      "Bash(git -C */.paseo/worktrees/* rebase:*)",
      "Bash(git -C */.paseo/worktrees/* checkout:*)",
      "Bash(git -C */.paseo/worktrees/* pull:*)",
      "Bash(git -C */.paseo/worktrees/* stash:*)",
      "Bash(git -C */.paseo/worktrees/* reset:*)",

      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(cut:*)",
      "Bash(jq:*)",
      "Bash(diff:*)",
      "Bash(cmp:*)",
      "Bash(ls:*)",
      "Bash(stat:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(pwd:*)",

      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(git grep:*)",
      "Bash(git -C */.paseo/worktrees/* grep:*)",

      "Bash(scripts/check-py:*)",
      "Bash(scripts/test-py:*)",
      "Bash(scripts/sandbox-py:*)",
      "Bash(scripts/sandbox-run:*)",
      "Bash(scripts/sandbox-bun:*)",

      "Bash(uv sync:*)",

      "Bash(docker compose -f docker-compose.dev.yml up:*)",
      "Bash(docker compose -f docker-compose.dev.yml down:*)",
      "Bash(docker compose -f docker-compose.dev.yml logs:*)",
      "Bash(docker compose -f docker-compose.dev.yml ps:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git -C */.paseo/worktrees/* push:*)",
      "Write(tmp_*)",
      "Edit(tmp_*)",
      "Write(**/tmp_*)",
      "Edit(**/tmp_*)",

      "Bash(rg --pre*)",
      "Bash(rg *--pre*)",
      "Bash(rg *--hostname-bin*)",
      "Bash(git grep -O*)",
      "Bash(git grep *-O*)",
      "Bash(git grep --open-files-in-pager*)",
      "Bash(git grep *--open-files-in-pager*)",
      "Bash(git -C */.paseo/worktrees/* grep -O*)",
      "Bash(git -C */.paseo/worktrees/* grep *-O*)",
      "Bash(git -C */.paseo/worktrees/* grep --open-files-in-pager*)",
      "Bash(git -C */.paseo/worktrees/* grep *--open-files-in-pager*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledMcpjsonServers": [
    "playwright"
  ]
}
