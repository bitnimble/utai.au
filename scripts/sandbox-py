#!/usr/bin/env bash
# scripts/sandbox-py '<python code>' [argv...]
#
# Run a Python snippet inside the utai sandbox container, like
# `python3 -c "..."`. Any extra args after the code become sys.argv[1:].
#
#   scripts/sandbox-py 'import torch; print(torch.cuda.is_available())'
#   scripts/sandbox-py 'import sys; print(sys.argv[1:])' foo bar
#
# A single `.py` FILE argument is run as a script instead of as a code
# string (the repo is mounted at the same path in the container, so a temp
# file Write()n in the repo resolves identically). Extra args still become
# sys.argv[1:]:
#   scripts/sandbox-py /abs/path/in/repo/tmp/a1b2c3.py foo bar
#
# Reads code from stdin if no argument is given:
#   scripts/sandbox-py < some_script.py
#
# The container runs as UID 1000 with /codebox-workspace mounted, so the
# snippet can read prior output and write scratch to /sandbox.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ $# -ge 1 ]; then
    if [[ "$1" == *.py && -f "$1" ]]; then
        # file path -> run as a script (argv after it -> sys.argv[1:])
        exec "$SCRIPT_DIR/sandbox-run" python3 "$@"
    fi
    code=$1
    shift
else
    code=$(cat)
fi

exec "$SCRIPT_DIR/sandbox-run" python3 -c "$code" "$@"
