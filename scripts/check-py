#!/usr/bin/env bash
# scripts/check-py [pytest-args...]
#
# Python post-change checks over the aligner backend: ruff (with --fix), then
# pytest. A bare `scripts/check-py` runs the whole suite; any args are passed
# through to pytest for fast single-test iteration, e.g.
# `scripts/check-py tests/test_foo.py::test_bar`.
#
# Requires aligner/.venv (uv-managed). Does NOT install deps, see
# aligner/Dockerfile / the project's Python env notes for the install recipe.
#
# Torch caveat: any test that needs a WORKING CUDA torch won't run on a host
# without one (e.g. the codebox host, where libcusparseLt is missing); run those
# in the sandbox instead: `scripts/sandbox-run python3 -m pytest aligner/tests`.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="$(cd "$SCRIPT_DIR/.." && pwd)"
VENV="$REPO/aligner/.venv"

if [ ! -d "$VENV" ]; then
    echo "error: aligner/.venv not found." >&2
    echo "       create it with: cd aligner && uv venv (then install deps per AGENTS.md §3)" >&2
    exit 1
fi

# ruff + pytest live in the `dev` dependency-group (in default-groups), so a
# plain `uv sync` installs them; a stale `--no-default-groups` venv won't have them.
if [ ! -x "$VENV/bin/ruff" ] || [ ! -x "$VENV/bin/pytest" ]; then
    echo "error: aligner/.venv is missing the dev tooling (ruff/pytest)." >&2
    echo "       re-sync to install the default dependency-groups:" >&2
    echo "           cd aligner && uv sync" >&2
    exit 1
fi

echo "== ruff check --fix (aligner) =="
"$VENV/bin/ruff" check --fix "$REPO/aligner"

echo
echo "== pytest: aligner =="
( cd "$REPO/aligner" && "$VENV/bin/pytest" "$@" )
