{
  "name": "utai.au",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "repository": "git@github.com:bitnimble/utai.au.git",
  "author": "D <me@kumo.dev>",
  "license": "MIT",
  "scripts": {
    "dev": "bunx vite",
    "build": "bun run lint:design && bunx tsc --noEmit && bunx vite build",
    "preview": "bunx vite preview",
    "typecheck": "bunx tsc --noEmit",
    "lint:design": "stylelint --fix 'frontend/src/**/*.css'",
    "test": "bun test",
    "e2e": "bun --env-file=.env run e2e:run",
    "e2e:run": "playwright test",
    "e2e:perf": "bun --env-file=.env run playwright test --project=perf --no-deps",
    "e2e:live": "bun --env-file=.env run playwright test -c playwright.live.config.ts",
    "e2e:report": "playwright show-report --host 0.0.0.0",
    "e2e:tauri:build": "bun run scripts/build-wdio-app.ts",
    "e2e:tauri": "bun run e2e:tauri:build && wdio run wdio.conf.ts",
    "tauri": "bun run scripts/tauri-build.ts",
    "win:build": "bun --env-file=.env run scripts/win-build.ts",
    "android:init": "bun run scripts/tauri-build.ts android init",
    "android:dev": "bun run scripts/tauri-build.ts android dev --config '{\"bundle\":{\"resources\":[]}}'",
    "android:build": "bun run scripts/tauri-build.ts android build --target aarch64 --target armv7 --apk --config '{\"bundle\":{\"resources\":[]}}'",
    "desktop:resources": "bun run scripts/prepare-desktop-resources.ts",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "postinstall": "bun run scripts/copy-kuromoji-dict.ts"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@sglkc/kuromoji": "^1.1.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "classnames": "^2.5.1",
    "lucide-react": "^1.16.0",
    "mobx": "^6.13.5",
    "mobx-react-lite": "^4.0.7",
    "mobx-utils": "^6.1.0",
    "onnxruntime-web": "^1.27.0",
    "react": "^18.3.1",
    "react-colorful": "^5.7.0",
    "react-dom": "^18.3.1",
    "signalsmith-stretch": "^1.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@storybook/react-vite": "^9",
    "@tauri-apps/cli": "^2.11.4",
    "@types/bun": "^1.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-plugin": "1.2.0",
    "@wdio/tauri-service": "1.2.0",
    "autoprefixer": "^10.5.2",
    "expect-webdriverio": "^5.7.0",
    "postcss": "^8.5.16",
    "storybook": "^9",
    "stylelint": "^17.12.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-css-modules": "^1.16.0"
  },
  "browserslist": [
    "last 2 years",
    "not dead",
    "not op_mini all"
  ],
  "patchedDependencies": {
    "@wdio/native-utils@2.4.0": "patches/@wdio%2Fnative-utils@2.4.0.patch"
  }
}
