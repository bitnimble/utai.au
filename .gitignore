.claude/settings.local.json

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage
*.lcov
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional caches
.npm
.eslintcache
.cache

# Output of 'npm pack'
*.tgz

dist

# Python backend (aligner/) service-specific paths. Generic Python artifacts
# (venv / egg-info / caches) are ignored globally below.
aligner/.env
aligner/data
aligner/models
aligner/debug
aligner/build

# Python tooling (general).
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# kuromoji dictionary, copied from node_modules into public/ by
# scripts/copy-kuromoji-dict.ts (postinstall). Lazy-fetched at runtime
# for Japanese lyrics; a few MB of generated assets, not source.
frontend/public/kuromoji-dict/

# Storybook static build output (`bun run build-storybook`).
storybook-static/

# Scratch report written by the /overnight skill (uncommitted morning log).
OVERNIGHT_LOG.md

# OS noise
.DS_Store
Thumbs.db

# Editor / IDE local settings (per-user).
.idea/
.cursor/
*.swp
*.swo
*~

# Bun caches (per-project / per-user)
.bun/

# Playwright e2e artifacts.
test-results/
playwright-report/
blob-report/
.playwright/
frontend/tests/*.png

# Scratch / experiment artifacts. `/tmp/` is the holding folder; `/tmp_*` is a
# safety net for tools that hardcode a repo-root output path.
/tmp/
/tmp_*

# Brainstorming visual companion
.superpowers/

# dotenv environment variables file
.env
.env.test
